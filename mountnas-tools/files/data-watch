#!/bin/sh
# data-watch — flip /run/mountnas/data when the system disk vanishes at runtime.
# Run from /etc/periodic/15min (crond). The mountnas service judges storage only
# at start, so a data disk that died while running left the state saying 'ok'
# forever — 'nas status' and the login banner lied until the next restart. This
# is detection only (state file + log): services are deliberately left alone,
# both because a transient USB reset must not take Docker down and because
# mount/placeholder handling belongs to the mountnas service ('nas restart').
STATE=/run/mountnas
DATA=/mnt/nasdata
LOG=/var/log/mountnas.log
log() { printf '%s data-watch: %s\n' "$(date '+%F %T')" "$*" >> "$LOG" 2>/dev/null; }
# Email the alert when /etc/mountnas/alert-email holds an address (and msmtp
# is configured — see the msmtprc template). Fires only on the ok->bad
# TRANSITION: this script exits early unless the state is 'ok', so a flip
# here can never repeat-spam on later runs.
_alert() {
	to=$(sed -e 's/#.*//' -e '/^[[:space:]]*$/d' /etc/mountnas/alert-email 2>/dev/null | head -n1)
	[ -n "$to" ] || return 0
	command -v mail >/dev/null 2>&1 || return 0
	printf '%s\n\nHost: %s\nTime: %s\n\nCheck it:  nas status\nRecover:   nas restart\n' \
		"$1" "$(hostname)" "$(date '+%F %T')" \
		| mail -s "[$(hostname)] MountNAS ALERT: $1" "$to" 2>>"$LOG" || log "alert mail failed"
}

[ "$(cat "$STATE/data" 2>/dev/null)" = ok ] || exit 0
spec=$(awk '$1!~/^#/ && $2=="/mnt/nasdata"{print $1; exit}' /etc/fstab)
[ -n "$spec" ] || exit 0

# device gone (yanked, died, USB reset that never came back)? Tag specs only —
# a bind-mount source path has no device to ask; the read probe below covers it.
present=1
case "$spec" in
	UUID=*|LABEL=*|PARTUUID=*) findfs "$spec" >/dev/null 2>&1 || present=0 ;;
	/dev/*) [ -b "$spec" ] || present=0 ;;
esac
if [ "$present" = 0 ]; then
	echo disconnected > "$STATE/data"
	log "$DATA device ($spec) no longer present — state set to disconnected; run: nas status"
	_alert "data disk DISCONNECTED ($spec no longer present)"
	exit 0
fi

# A mountpoint can outlive its device: /proc/mounts keeps listing it rw while
# every access returns EIO (observed with a hot-detached disk backing a bind
# mount — the old checks all passed while touch failed). A directory read
# catches exactly that; the system disk hosts Docker and is never spun down,
# so the probe cannot wake anything.
if ! ls "$DATA" >/dev/null 2>&1; then
	echo mountfail > "$STATE/data"
	log "$DATA is unreadable (dead mount — device detached?) — state set to mountfail; run: nas restart"
	_alert "data disk UNREADABLE (dead mount — device detached?)"
	exit 0
fi

# filesystem errors flip ext4/xfs to read-only in place (errors=remount-ro);
# the mount then looks healthy to mountpoint(1) while every write fails
if awk -v m="$DATA" '$2==m && $4 ~ /^ro(,|$)/ {f=1} END{exit !f}' /proc/mounts; then
	echo mountfail > "$STATE/data"
	log "$DATA is mounted read-only (filesystem errors?) — state set to mountfail; run: nas status"
	_alert "data disk mounted READ-ONLY (filesystem errors?)"
fi
exit 0
