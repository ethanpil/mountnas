#!/bin/sh
# gen-webstatus — render the read-only status dashboard into the tmpfs webroot.
#
# Design (see CONTEXT.md): NO request-time code. A root-run refresher renders
# static index.html + status.json into /run/mountnas/web every ~2 minutes and
# busybox httpd serves only those files — the attack surface is "serve static
# files", and tmpfs means zero disk writes (no drive spin-up, no flash wear).
# Everything shown comes from 'nas status --json' + 'nas disks --json' (no
# secrets by construction) plus /proc//sys/file reads — nothing here may ever
# wake a sleeping disk (SMART is -n standby + cached; power state is an
# ioctl; /cfg and /mnt/nasdata are always-awake by design) or run
# request-driven logic.
WEB=${WEB:-/run/mountnas/web}
CFG=/cfg
DATA=/mnt/nasdata
mkdir -p "$WEB"

esc() { sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g'; }
hum_kb() { # KB -> human
	awk -v k="${1:-0}" 'BEGIN{ if (k>=1073741824) printf "%.1f TB", k/1073741824;
		else if (k>=1048576) printf "%.1f GB", k/1048576;
		else if (k>=1024) printf "%.0f MB", k/1024; else printf "%d KB", k }'
}

# status --json exits 1 when a check FAILs — the output is still the snapshot
# we want. Guard with jq so a hard failure degrades to an "unknown" page.
sj=$(NO_COLOR=1 nas status --json 2>/dev/null) || true
dj=$(NO_COLOR=1 nas disks --json 2>/dev/null) || true
printf '%s' "$sj" | jq -e . >/dev/null 2>&1 || sj='{}'
printf '%s' "$dj" | jq -e . >/dev/null 2>&1 || dj='{}'

# machine-readable copy for integrations (atomic swap; linked in the footer)
printf '%s\n' "$sj" > "$WEB/status.json.new" && mv "$WEB/status.json.new" "$WEB/status.json"

state=$(printf '%s' "$sj" | jq -r '
	if (.checks.fail // 0) > 0 then "fail"
	elif (.checks.warn // 0) > 0 then "warn"
	elif .healthy == true then "ok"
	else "unknown" end')
case "$state" in
	ok)      state_word="Healthy" ;;
	warn)    state_word="Warnings" ;;
	fail)    state_word="Attention" ;;
	*)       state_word="Unknown" ;;
esac

host=$(printf '%s' "$sj" | jq -r '.hostname // "mountnas" | @html')
rel=$(printf '%s' "$sj" | jq -r '.release // "?" | @html')
build=$(printf '%s' "$sj" | jq -r '.version // "?" | @html')
ips=$(printf '%s' "$sj" | jq -r '[.ips[]? | @html] | join(" &middot; ") | if . == "" then "?" else . end')
up=$(printf '%s' "$sj" | jq -r '(.uptime_seconds // 0) |
	if . >= 86400 then "\(. / 86400 | floor)d \(. % 86400 / 3600 | floor)h"
	elif . >= 3600 then "\(. / 3600 | floor)h \(. % 3600 / 60 | floor)m"
	else "\(. / 60 | floor)m" end')
datastate=$(printf '%s' "$sj" | jq -r '.data_disk // "?"')
cfgstate=$(printf '%s' "$sj" | jq -r '.config_partition // "?"')
unsaved=$(printf '%s' "$sj" | jq -r '.unsaved_changes // 0')
lastbk=$(printf '%s' "$sj" | jq -r '(.last_backup_epoch // 0) |
	if . > 0 then (. | strflocaltime("%Y-%m-%d %H:%M")) else "never" end' 2>/dev/null || echo "never")
gen_at=$(date '+%Y-%m-%d %H:%M:%S')

# ---- cheap /proc//sys data points -------------------------------------------
loadavg=$(cut -d' ' -f1-3 /proc/loadavg 2>/dev/null || echo "?")
cores=$(nproc 2>/dev/null || echo "?")
mem=$(awk '/^MemTotal:/{t=$2} /^MemAvailable:/{a=$2}
	END{ if (t>0) printf "%.1f used &middot; %.1f avail &middot; %.1f GB total", (t-a)/1048576, a/1048576, t/1048576; else print "?" }' /proc/meminfo 2>/dev/null)
# RAM root fill matters on a diskless box: a full / breaks 'nas commit'
ramroot=$(df -k / 2>/dev/null | awk 'NR==2{printf "%d%% of %.1f GB", $3*100/$2, $2/1048576}')
ramroot_pct=$(df -k / 2>/dev/null | awk 'NR==2{printf "%d", $3*100/$2}')
if [ "${ramroot_pct:-0}" -ge 80 ] 2>/dev/null; then
	ramroot_html="<span class=\"pill p-warn\">$ramroot</span>"
else
	ramroot_html="<span class=\"num\">$ramroot</span>"
fi
kern="$(uname -r 2>/dev/null || echo '?') &middot; Alpine $(cat /etc/alpine-release 2>/dev/null || echo '?')"
cputemp="-"
for h in /sys/class/hwmon/hwmon*; do
	[ -f "$h/name" ] || continue
	case "$(cat "$h/name" 2>/dev/null)" in
	coretemp|k10temp|zenpower|cpu_thermal|soc_thermal|acpitz)
		t=$(cat "$h/temp1_input" 2>/dev/null) || continue
		case "$t" in *[!0-9]*|'') continue ;; esac
		cputemp="$((t / 1000))&deg;C"; break ;;
	esac
done
# fan RPMs from any hwmon that exposes them (row omitted when none)
fans=""
for f in /sys/class/hwmon/hwmon*/fan*_input; do
	[ -f "$f" ] || continue
	r=$(cat "$f" 2>/dev/null)
	case "$r" in ''|*[!0-9]*|0) continue ;; esac
	fans="$fans${fans:+ &middot; }$r rpm"
done
fans_row=""
[ -n "$fans" ] && fans_row="<dt>Fans</dt><dd class=\"num\">$fans</dd>"
procs=$(find /proc -maxdepth 1 -name '[0-9]*' 2>/dev/null | grep -c .)
logins=$(who 2>/dev/null | wc -l | tr -d ' ')
lastcommit=$(date -r "$CFG/$(hostname).apkovl.tar.gz" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "never")
# grep -c always prints a count — no || fallback (it would emit a SECOND
# line on the no-match exit-1 path and make $sinks non-numeric)
sinks=$(/usr/libexec/mountnas/notify --list 2>/dev/null | grep -c .)
if [ "${sinks:-0}" -gt 0 ] 2>/dev/null; then
	sinks_html="<span class=\"pill p-ok\">$sinks sink(s)</span>"
else
	sinks_html="<span class=\"pill p-off\">off</span>"
fi
pkgcount=$(apk info 2>/dev/null | wc -l | tr -d ' ')
: "${pkgcount:=?}"
cpu_model=$(awk -F': *' '/^model name/{print $2; exit}' /proc/cpuinfo 2>/dev/null)
[ -n "$cpu_model" ] || cpu_model="?"
hw_vendor=$(cat /sys/class/dmi/id/sys_vendor 2>/dev/null || true)
hw_product=$(cat /sys/class/dmi/id/product_name 2>/dev/null || true)
hw="${hw_vendor:+$hw_vendor }${hw_product:-?}"
now_tz=$(date '+%Y-%m-%d %H:%M:%S %Z')

# ---- config-partition footprint (always-awake USB, metadata reads only) ----
ovl_kb=$(du -k "$CFG/$(hostname).apkovl.tar.gz" 2>/dev/null | cut -f1)
cache_kb=$(du -sk "$CFG/cache" 2>/dev/null | cut -f1)
ovl_sz=$([ -n "$ovl_kb" ] && hum_kb "$ovl_kb" || echo "-")
cache_sz=$([ -n "$cache_kb" ] && hum_kb "$cache_kb" || echo "-")

# ---- protection: backups on disk + snapraid parity age ----------------------
bk_html='<span class="mut">none on disk</span>'
if mountpoint -q "$DATA" 2>/dev/null; then
	bk_n=$(find "$DATA/backups" -maxdepth 1 -name 'mountnas-backup-*.img.gz' 2>/dev/null | wc -l | tr -d ' ')
	if [ "${bk_n:-0}" -gt 0 ] 2>/dev/null; then
		bk_new=$(ls -t "$DATA"/backups/mountnas-backup-*.img.gz 2>/dev/null | head -n1)
		bk_html="<span class=\"num\">$bk_n on disk &middot; newest $(date -r "$bk_new" '+%Y-%m-%d' 2>/dev/null)</span>"
	fi
fi
sr_html='<span class="mut">not configured</span>'
sr_content=$(awk '$1=="content"{print $2; exit}' /etc/snapraid.conf 2>/dev/null)
if [ -n "$sr_content" ]; then
	if [ -f "$sr_content" ]; then
		sr_age=$(( ( $(date +%s) - $(date -r "$sr_content" +%s 2>/dev/null || date +%s) ) / 86400 ))
		if [ "$sr_age" -ge 8 ]; then
			sr_html="<span class=\"pill p-warn\">synced $sr_age day(s) ago</span>"
		else
			sr_html="<span class=\"pill p-ok\">synced $sr_age day(s) ago</span>"
		fi
	else
		sr_html='<span class="pill p-warn">configured, never synced</span>'
	fi
fi

# ---- services (core from status --json; off-by-default probed here) --------
services=$(printf '%s' "$sj" | jq -r '
	[.services[]? |
	  if .running then "<span class=\"pill p-ok\"><i></i>\(.name | @html)</span>"
	  else "<span class=\"pill p-off\"><i></i>\(.name | @html)</span>" end
	] | join(" ")')
[ -n "$services" ] || services='<span class="mut">no service data</span>'
# a stopped optional service is a neutral "off", never a warning — exactly why
# these cannot join the cmd_status service loop, which warns on stopped entries
for s in tailscale zerotier-one nut-upsd nut-upsmon; do
	if rc-service "$s" status >/dev/null 2>&1; then
		services="$services <span class=\"pill p-ok\"><i></i>$s</span>"
	else
		services="$services <span class=\"pill p-off\"><i></i>$s</span>"
	fi
done
wg_ifs=$(wg show interfaces 2>/dev/null | tr '\n' ' ')
if [ -n "${wg_ifs% }" ]; then
	services="$services <span class=\"pill p-ok\"><i></i>wireguard (${wg_ifs% })</span>"
else
	services="$services <span class=\"pill p-off\"><i></i>wireguard</span>"
fi
# context lines under the pills: VPN addresses + UPS state, only when up
svc_extra=""
if rc-service tailscale status >/dev/null 2>&1; then
	ts_ip=$(tailscale ip -4 2>/dev/null | head -n1)
	[ -n "$ts_ip" ] && svc_extra="$svc_extra<div class=\"mut svcx\">tailscale: <span class=\"num\">$ts_ip</span></div>"
fi
if rc-service zerotier-one status >/dev/null 2>&1; then
	zt=$(zerotier-cli listnetworks 2>/dev/null | awk 'NR>1 && $NF ~ /\// {printf "%s%s", (c++?", ":""), $NF}')
	[ -n "$zt" ] && svc_extra="$svc_extra<div class=\"mut svcx\">zerotier: <span class=\"num\">$(printf '%s' "$zt" | esc)</span></div>"
fi
if rc-service nut-upsd status >/dev/null 2>&1; then
	ups_name=$(upsc -l 2>/dev/null | head -n1)
	if [ -n "$ups_name" ]; then
		ups_stat=$(upsc "$ups_name" ups.status 2>/dev/null)
		ups_chg=$(upsc "$ups_name" battery.charge 2>/dev/null)
		ups_rt=$(upsc "$ups_name" battery.runtime 2>/dev/null)
		# some drivers omit battery.runtime or report N/A — never feed that
		# into arithmetic (ash errors and the raw string leaks into the page)
		case "$ups_rt" in ''|*[!0-9]*) ups_rt="" ;; *) ups_rt="$((ups_rt / 60)) min" ;; esac
		case "$ups_stat" in
			OL*) ups_pill="<span class=\"pill p-ok\">on line</span>" ;;
			OB*) ups_pill="<span class=\"pill p-fail\">ON BATTERY</span>" ;;
			*)   ups_pill="<span class=\"pill p-off\">$(printf '%s' "${ups_stat:-?}" | esc)</span>" ;;
		esac
		svc_extra="$svc_extra<div class=\"mut svcx\">UPS $(printf '%s' "$ups_name" | esc): $ups_pill <span class=\"num\">${ups_chg:+$ups_chg%}${ups_rt:+ &middot; $ups_rt}</span></div>"
	fi
fi

# ---- docker containers (guarded on the daemon; ~50 ms when up) --------------
# Every docker call is time-bounded: a wedged dockerd (e.g. the data disk died
# underneath it) otherwise blocks this renderer forever and the dashboard
# freezes at its last healthy render — exactly when it must not.
docker_html='<span class="mut">docker not running (held until the data disk is up)</span>'
if rc-service docker status >/dev/null 2>&1; then
	d_run=$(timeout 10 docker ps -q 2>/dev/null | wc -l | tr -d ' ')
	d_all=$(timeout 10 docker ps -aq 2>/dev/null | wc -l | tr -d ' ')
	d_list=$(timeout 10 docker ps -a --format '{{.Names}}\t{{.Status}}' 2>/dev/null | head -n 12 | esc \
		| awk -F'\t' '{ st = ($2 ~ /^Up/) ? "c-ok" : "c-off";
			printf "<li class=\"%s\"><b>%s</b> <span class=\"mut\">%s</span></li>\n", st, $1, $2 }')
	if [ "${d_all:-0}" -gt 0 ] 2>/dev/null; then
		docker_html="<div class=\"mut\" style=\"margin-bottom:6px\"><span class=\"num\">$d_run</span> running / <span class=\"num\">$d_all</span> total</div><ul class=\"checks\">$d_list</ul>"
	else
		docker_html='<span class="mut">daemon up &middot; unresponsive or no containers</span>'
	fi
fi

# ---- network interfaces (pure /sys reads) ------------------------------------
net_rows=""
for n in /sys/class/net/*; do
	i=${n##*/}
	[ "$i" = lo ] && continue
	oper=$(cat "$n/operstate" 2>/dev/null)
	rx=$(cat "$n/statistics/rx_bytes" 2>/dev/null || echo 0)
	tx=$(cat "$n/statistics/tx_bytes" 2>/dev/null || echo 0)
	spd=$(cat "$n/speed" 2>/dev/null)
	case "$spd" in ''|*[!0-9]*) spd="" ;; esac
	rx_h=$(hum_kb $((rx / 1024))); tx_h=$(hum_kb $((tx / 1024)))
	if [ "$oper" = up ]; then op="<span class=\"pill p-ok\"><i></i>up</span>"
	else op="<span class=\"pill p-off\"><i></i>${oper:-down}</span>"; fi
	net_rows="$net_rows<dt class=\"mono\">$i</dt><dd>$op ${spd:+<span class=\"num\">$spd Mb/s</span> &middot;} <span class=\"num mut\">&darr;$rx_h &uarr;$tx_h</span></dd>"
done
[ -n "$net_rows" ] || net_rows='<dt>-</dt><dd class="mut">no interfaces</dd>'

checks=$(printf '%s' "$sj" | jq -r '
	([.fail_lines[]? | "<li class=\"c-fail\">\(@html)</li>"] +
	 [.warn_lines[]? | "<li class=\"c-warn\">\(@html)</li>"]) | join("\n")')
if [ -z "$checks" ]; then
	if [ "$state" = ok ]; then checks='<li class="c-ok">All checks passed</li>'
	else checks='<li class="mut">no check data</li>'; fi
fi

# browser terminal (mountnas-ttyd): when it is running, the footer links to
# it by the box's first IP — the one address guaranteed reachable from any
# client that can see this page (mDNS names do not resolve everywhere)
ttyd_link=""
if rc-service mountnas-ttyd status >/dev/null 2>&1; then
	ttyd_port=$(sed -n 's/^PORT=//p' /etc/conf.d/mountnas-ttyd 2>/dev/null | head -n1)
	: "${ttyd_port:=22222}"
	ttyd_ip=$(printf '%s' "$sj" | jq -r '.ips[0] // empty')
	[ -n "$ttyd_ip" ] && ttyd_link="<a href=\"http://$ttyd_ip:$ttyd_port/\">Web terminal</a>"
fi

recent_ops=$(tail -n 4 "$CFG/mountnas-ops.log" 2>/dev/null | esc \
	| awk -F'\t' '{ printf "<li><span class=\"num mut\">%s</span> <b>%s</b> <span class=\"mut\">%s</span></li>\n", substr($1,1,16), $2, $4 }')
[ -n "$recent_ops" ] || recent_ops='<li class="mut">none yet — commits, backups and upgrades land here</li>'

# ---- SMART overall health, STANDBY-SAFE and cached (15 min) ------------------
SMART_CACHE=/run/mountnas/websmart
if [ ! -f "$SMART_CACHE" ] || [ "$(( $(date +%s) - $(date -r "$SMART_CACHE" +%s 2>/dev/null || echo 0) ))" -ge 900 ]; then
	printf '%s' "$dj" \
	| jq -r '.disks[]? | select(.name | test("^(fd|sr|loop|ram|zram)") | not) | .name' \
	| while IFS= read -r d; do
		[ -n "$d" ] || continue
		sm=$(smartctl -n standby -H "/dev/$d" 2>/dev/null)
		case "$sm" in
			*PASSED*|*"SMART Health Status: OK"*) v=PASSED ;;
			*FAILED*)                             v=FAILED ;;
			*STANDBY*|*standby*)                  v=standby ;;
			*)                                    v=n/a ;;
		esac
		printf '%s\t%s\n' "$d" "$v"
	done > "$SMART_CACHE.new" && mv "$SMART_CACHE.new" "$SMART_CACHE"
fi
smart_map=$(awk -F'\t' '{printf "{\"k\":\"%s\",\"v\":\"%s\"}\n", $1, $2}' "$SMART_CACHE" 2>/dev/null \
	| jq -s 'map({(.k): .v}) | add // {}')
[ -n "$smart_map" ] || smart_map='{}'

# ---- disk power state (hdparm -C is an ioctl; never wakes a drive) -----------
power_map=$(printf '%s' "$dj" \
	| jq -r '.disks[]? | select(.name | test("^(fd|sr|loop|ram|zram)") | not) | .name' \
	| while IFS= read -r d; do
		[ -n "$d" ] || continue
		p=$(hdparm -C "/dev/$d" 2>/dev/null | awk -F': *' '/drive state/{print $2}')
		case "$p" in
			*active*|*idle*) v=active ;;
			*standby*|*sleeping*) v=standby ;;
			*) v=- ;;
		esac
		printf '{"k":"%s","v":"%s"}\n' "$d" "$v"
	done | jq -s 'map({(.k): .v}) | add // {}')
[ -n "$power_map" ] || power_map='{}'

# every partition that carries a filesystem is listed (mounted ones with a
# used-fill bar + free space); junk devices (floppy/cdrom/loop) filtered out
disk_rows=$(printf '%s' "$dj" | jq -r --argjson smart "$smart_map" --argjson power "$power_map" '
	def hum: if . == null then "?"
		elif . >= 1099511627776 then "\(. / 1099511627776 * 10 | round / 10) TB"
		elif . >= 1073741824 then "\(. / 1073741824 * 10 | round / 10) GB"
		else "\(. / 1048576 | floor) MB" end;
	def bar: (if . >= 90 then "b-fail" elif . >= 80 then "b-warn" else "" end) as $c |
		"<span class=\"bar \($c)\"><i style=\"width:\(.)%\"></i></span>";
	.disks[]? | select(.name | test("^(fd|sr|loop|ram|zram)") | not) |
	"<tr><td class=\"mono\">\(.name | @html)\(if .boot_usb then " <span class=\"pill p-boot\">boot USB</span>" else "" end)</td>" +
	"<td>\((.model // .vendor // "?") | @html)</td>" +
	"<td class=\"num\">\(.size | hum)</td>" +
	"<td>\(if .rotational then "HDD" else "SSD" end)</td>" +
	"<td>\( ($power[.name] // "-") as $pv |
		if $pv == "active" then "<span class=\"pill p-ok\">active</span>"
		elif $pv == "standby" then "<span class=\"pill p-off\">standby</span>"
		else "<span class=\"mut\">-</span>" end)</td>" +
	"<td class=\"num\">\((.temp // "-") | @html)</td>" +
	"<td>\( ($smart[.name] // "n/a") as $sv |
		if $sv == "PASSED" then "<span class=\"pill p-ok\">PASSED</span>"
		elif $sv == "FAILED" then "<span class=\"pill p-fail\">FAILED</span>"
		elif $sv == "standby" then "<span class=\"pill p-off\">standby</span>"
		else "<span class=\"mut\">n/a</span>" end)</td>" +
	"<td>\([ .partitions[]? | select(.fstype != null) |
		if .mountpoint != null then
			((if (.size // 0) > 0 and .fsavail != null then (100 - (.fsavail * 100 / .size) | floor) else null end)) as $pct |
			"<span class=\"mnt\"><b>\((.label // .name) | @html)</b> &rarr; \(.mountpoint | @html) \(if $pct != null then ($pct | bar) else "" end) <span class=\"mut\">&middot; \(.fstype | @html) &middot; \(.fsavail | hum) free</span></span>"
		else
			"<span class=\"mnt mut\"><b>\((.label // .name) | @html)</b> &middot; \(.fstype | @html) &middot; not mounted</span>"
		end
	  ] | if length == 0 then "<span class=\"mut\">no filesystem</span>" else join("<br>") end)</td></tr>"')
[ -n "$disk_rows" ] || disk_rows='<tr><td colspan="8" class="mut">no disk data</td></tr>'

# mergerfs pools are fuse mounts (invisible to lsblk) — appended as rows.
# /proc/mounts octal-escapes spaces as \040: decode with %b or df misses the
# path and the pool silently vanishes from the table.
pool_rows=$(awk '$3=="fuse.mergerfs"{print $2}' /proc/mounts 2>/dev/null \
	| while IFS= read -r mp_raw; do
		mp=$(printf '%b' "$mp_raw")
		df -kP "$mp" 2>/dev/null | awk -v mp="$mp" 'NR==2 {
			pct = int($3 * 100 / $2);
			cls = (pct >= 90) ? "b-fail" : (pct >= 80) ? "b-warn" : "";
			printf "<tr><td class=\"mono\">pool</td><td>mergerfs</td><td class=\"num\">%.1f GB</td><td>POOL</td><td><span class=\"mut\">-</span></td><td class=\"num\">-</td><td><span class=\"mut\">-</span></td><td><span class=\"mnt\"><b>pool</b> &rarr; %s <span class=\"bar %s\"><i style=\"width:%d%%\"></i></span> <span class=\"mut\">&middot; fuse.mergerfs &middot; %.1f GB free</span></span></td></tr>\n",
				$2/1048576, mp, cls, pct, $4/1048576 }'
	done)
disk_rows="$disk_rows$pool_rows"

# ---- hardware inventory: USB tree, PCI devices, memory modules ---------------
# All three read sysfs/SMBIOS tables only (microseconds, never a disk touch).
usb_tree=$(lsusb -tv 2>/dev/null | esc)
[ -n "$usb_tree" ] || usb_tree="(no USB devices visible)"
pci_list=$(lspci 2>/dev/null | esc)
[ -n "$pci_list" ] || pci_list="(no PCI devices visible)"
dimms=$(dmidecode -t 17 2>/dev/null | awk -F': ' '
	function flush() {
		if (size != "" && size !~ /No Module/)
			printf "%-16s %-10s %-8s %-14s %s\n", loc, size, type, spd, man
	}
	/^Handle /       { flush(); loc=size=type=spd=man="" }
	/^\tSize: /      { size=$2 }
	/^\tLocator: /   { loc=$2 }
	/^\tType: /      { type=$2 }
	/^\tSpeed: /     { spd=$2 }
	/^\tManufacturer: / { man=$2 }
	END { flush() }' | esc)
[ -n "$dimms" ] || dimms="(no DMI memory-module data)"

# ---- release-base diff + cron + unsaved list + syslog tail -------------------
wb=$(find /media -maxdepth 2 -name world.base 2>/dev/null | head -n1)
if [ -n "$wb" ] && [ -s "$wb" ]; then
	extras=$(awk 'NR==FNR{a[$1];next} !($1 in a)' "$wb" /etc/apk/world 2>/dev/null \
		| esc | awk '{printf "<code>%s</code> ", $1}')
	[ -n "$extras" ] || extras='<span class="mut">none — stock image</span>'
else
	extras='<span class="mut">(release package list not readable)</span>'
fi
cron_html=$(crontab -l 2>/dev/null | grep -vE '^[[:space:]]*(#|$)' | head -n 12 | esc)
[ -n "$cron_html" ] || cron_html="(no scheduled jobs — snapraid sync and the health digest go here)"
# run the /etc-walking lbu status ONLY when the count (already computed by
# status --json above) says there is something to list — in the committed
# steady state this saves a full lbu walk every render
if [ "${unsaved:-0}" -gt 0 ] 2>/dev/null; then
	unsaved_list=$(lbu status 2>/dev/null | head -n 40 | esc)
	[ -n "$unsaved_list" ] || unsaved_list="(nothing — all changes are committed)"
else
	unsaved_list="(nothing — all changes are committed)"
fi
syslog_file=$(sed -n 's/.*-O \([^ "]*\).*/\1/p' /etc/conf.d/syslog 2>/dev/null | head -n1)
[ -n "$syslog_file" ] && [ -f "$syslog_file" ] || syslog_file=/var/log/messages
syslog_html=$(tail -n 100 "$syslog_file" 2>/dev/null | esc)
[ -n "$syslog_html" ] || syslog_html="(no syslog entries yet)"

case "$datastate" in
	ok) data_cls=ok; data_word="mounted" ;;
	fresh) data_cls=warn; data_word="not configured yet" ;;
	*) data_cls=fail; data_word="$datastate" ;;
esac
if [ "${unsaved:-0}" -gt 0 ] 2>/dev/null; then
	unsaved_html="<span class=\"pill p-warn\">$unsaved unsaved &mdash; nas commit</span>"
else
	unsaved_html="<span class=\"pill p-ok\">none</span>"
fi

# ---- stylesheet --------------------------------------------------------------
css=$(cat <<'CSSEOF'
:root{--bg:#eef2f6;--card:#fff;--ink:#16222e;--mut:#5c6b7a;--line:#d9e1e9;
--navy:#043b62;--acc:#1273b8;--ok:#148a46;--okbg:#e2f3e9;--warn:#8a6100;
--warnbg:#f7edd0;--fail:#c22d23;--failbg:#fae4e2;--off:#5c6b7a;--offbg:#e7ecf1}
@media(prefers-color-scheme:dark){:root{--bg:#0d151d;--card:#152230;--ink:#e4edf5;
--mut:#8ea1b3;--line:#233648;--navy:#043b62;--acc:#4aa3e0;--ok:#3cc776;--okbg:#12301e;
--warn:#e3ac3c;--warnbg:#2e2513;--fail:#ff6f64;--failbg:#341713;--off:#8ea1b3;--offbg:#1b2a3a}}
*{box-sizing:border-box;margin:0}
body{background:var(--bg);color:var(--ink);font:15px/1.5 system-ui,-apple-system,"Segoe UI",sans-serif}
.mono{font-family:ui-monospace,Menlo,Consolas,monospace}
.num{font-variant-numeric:tabular-nums;white-space:nowrap}
.mut{color:var(--mut)}
header{background:var(--navy);color:#fff;padding:14px 20px;display:flex;align-items:center;gap:14px;flex-wrap:wrap}
header img{width:44px;height:44px;border-radius:9px}
header h1{font-size:20px;line-height:1.2}
header .sub{color:#a8c4dc;font-size:12.5px}
header .spacer{flex:1}
.state{font-weight:700;padding:7px 16px;border-radius:22px;font-size:14px}
.state.ok{background:#1d9d55;color:#fff}.state.warn{background:#e0a93a;color:#3a2b00}
.state.fail{background:#e04b40;color:#fff}.state.unknown{background:#5c6b7a;color:#fff}
header .upd{color:#a8c4dc;font-size:11.5px;text-align:right}
.wrap{max-width:1080px;margin:0 auto;padding:18px 20px 40px}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:14px;margin-bottom:14px}
.card{background:var(--card);border:1px solid var(--line);border-radius:10px;padding:14px 16px}
.card h2{font-size:11px;letter-spacing:.09em;text-transform:uppercase;color:var(--mut);margin-bottom:10px}
dl{display:grid;grid-template-columns:auto 1fr;gap:5px 14px;font-size:13.5px}
dt{color:var(--mut);white-space:nowrap}dd{text-align:right;overflow-wrap:anywhere}
.pill{display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:14px;font-size:12px;font-weight:600}
.pill i{width:7px;height:7px;border-radius:50%;background:currentColor;display:inline-block}
.p-ok{color:var(--ok);background:var(--okbg)}.p-warn{color:var(--warn);background:var(--warnbg)}
.p-fail{color:var(--fail);background:var(--failbg)}.p-off{color:var(--off);background:var(--offbg)}
.p-boot{color:var(--acc);background:var(--offbg);font-size:10.5px}
.svc{display:flex;flex-wrap:wrap;gap:7px}
.svcx{font-size:12.5px;margin-top:7px}
ul.checks,ul.ops{list-style:none;font-size:13px}
ul.checks li{padding:4px 0 4px 20px;position:relative}
ul.checks li::before{content:"";position:absolute;left:4px;top:11px;width:8px;height:8px;border-radius:50%}
.c-ok::before{background:var(--ok)}.c-warn::before{background:var(--warn)}.c-fail::before{background:var(--fail)}
.c-off::before{background:var(--off)}
.c-fail{color:var(--fail);font-weight:600}.c-warn{color:var(--warn)}
ul.ops li{padding:4px 0;border-bottom:1px dashed var(--line)}
ul.ops li:last-child{border-bottom:none}
.bar{display:inline-block;width:64px;height:6px;background:var(--offbg);border-radius:3px;overflow:hidden;vertical-align:middle}
.bar i{display:block;height:100%;background:var(--ok)}
.bar.b-warn i{background:var(--warn)}.bar.b-fail i{background:var(--fail)}
.tablecard{padding:0;overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13.5px}
th{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--mut);text-align:left;padding:11px 14px;border-bottom:1px solid var(--line)}
td{padding:10px 14px;border-bottom:1px solid var(--line);vertical-align:top}
tr:last-child td{border-bottom:none}
.mnt{display:inline-block}
pre.log{background:var(--card);padding:12px 16px;overflow-x:auto;
font:12px/1.55 ui-monospace,Menlo,Consolas,monospace;color:var(--ink);
max-height:60vh;overflow-y:auto;white-space:pre-wrap;word-break:break-word;
border-top:1px solid var(--line)}
details.card{padding:0;margin-bottom:14px}
details.card summary{cursor:pointer;padding:12px 16px;font-size:11px;
letter-spacing:.09em;text-transform:uppercase;color:var(--mut);font-weight:600;
list-style:none;display:flex;align-items:center;gap:8px}
details.card summary::before{content:"\25B8";font-size:10px;transition:transform .12s}
details.card[open] summary::before{transform:rotate(90deg)}
details.card summary .mut{text-transform:none;letter-spacing:0;font-weight:400}
.pkglist code{background:var(--offbg);border-radius:4px;padding:1px 6px;font-size:12px;
display:inline-block;margin:2px 2px}
footer{max-width:1080px;margin:0 auto;padding:0 20px 30px;color:var(--mut);font-size:12.5px;display:flex;gap:18px;flex-wrap:wrap}
footer a{color:var(--acc);text-decoration:none}
footer a:hover{text-decoration:underline}
CSSEOF
)

cat > "$WEB/index.html.new" <<EOF
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta http-equiv="refresh" content="120">
<title>$host &middot; MountNAS</title>
<link rel="icon" href="logo.png">
<style>
$css
</style>
</head>
<body>
<header>
  <img src="logo.png" alt="MountNAS">
  <div><h1>$host</h1><div class="sub">MountNAS $rel &middot; read-only dashboard</div></div>
  <div class="spacer"></div>
  <div class="state $state">$state_word</div>
  <div class="upd">updated $gen_at<br>refreshes every 2 min</div>
</header>
<main class="wrap">
  <div class="grid">
    <div class="card"><h2>Hardware</h2>
      <dl>
        <dt>Machine</dt><dd>$hw</dd>
        <dt>CPU</dt><dd>$cpu_model</dd>
        <dt>Cores</dt><dd class="num">$cores</dd>
        <dt>CPU temp</dt><dd class="num">$cputemp</dd>
        $fans_row
        <dt>Memory</dt><dd class="num">$mem</dd>
        <dt>Box time</dt><dd class="num">$now_tz</dd>
      </dl>
    </div>
    <div class="card"><h2>System</h2>
      <dl>
        <dt>Uptime</dt><dd class="num">$up</dd>
        <dt>Address</dt><dd class="num">$ips</dd>
        <dt>Load</dt><dd class="num">$loadavg <span class="mut">/ $cores cores</span></dd>
        <dt>RAM root</dt><dd>$ramroot_html</dd>
        <dt>Processes</dt><dd class="num">$procs <span class="mut">&middot; $logins login(s)</span></dd>
        <dt>Kernel</dt><dd class="num">$kern</dd>
        <dt>Packages</dt><dd class="num">$pkgcount installed</dd>
        <dt>Release</dt><dd>$rel <span class="mut">($build)</span></dd>
      </dl>
    </div>
    <div class="card"><h2>Config &amp; storage</h2>
      <dl>
        <dt>Data disk</dt><dd><span class="pill p-$data_cls"><i></i>$data_word</span></dd>
        <dt>Config partition</dt><dd><span class="pill p-$( [ "$cfgstate" = ok ] && echo ok || echo fail )"><i></i>$cfgstate</span></dd>
        <dt>Unsaved changes</dt><dd>$unsaved_html</dd>
        <dt>Last commit</dt><dd class="num">$lastcommit</dd>
        <dt>Overlay size</dt><dd class="num">$ovl_sz <span class="mut">&middot; cache $cache_sz</span></dd>
      </dl>
    </div>
    <div class="card"><h2>Protection</h2>
      <dl>
        <dt>Last backup</dt><dd class="num">$lastbk</dd>
        <dt>Backups</dt><dd>$bk_html</dd>
        <dt>SnapRAID parity</dt><dd>$sr_html</dd>
        <dt>Alert sinks</dt><dd>$sinks_html</dd>
      </dl>
    </div>
    <div class="card"><h2>Services</h2><div class="svc">$services</div>$svc_extra</div>
    <div class="card"><h2>Checks</h2><ul class="checks">
$checks
    </ul></div>
    <div class="card"><h2>Docker</h2>$docker_html</div>
    <div class="card"><h2>Network</h2><dl>$net_rows</dl></div>
    <div class="card"><h2>Recent operations</h2><ul class="ops">
$recent_ops
    </ul></div>
  </div>
  <div class="card tablecard" style="margin-bottom:14px">
    <table>
      <thead><tr><th>Disk</th><th>Model</th><th>Size</th><th>Type</th><th>Power</th><th>Temp</th><th>SMART</th><th>Filesystems</th></tr></thead>
      <tbody>
$disk_rows
      </tbody>
    </table>
  </div>
  <details class="card">
    <summary>Hardware inventory <span class="mut">(USB tree &middot; PCI devices &middot; memory modules)</span></summary>
    <pre class="log">== USB (lsusb -tv) ==
$usb_tree

== PCI (lspci) ==
$pci_list

== Memory modules (dmidecode -t 17) ==
$dimms</pre>
  </details>
  <div class="grid">
    <div class="card"><h2>Your added packages</h2>
      <div class="pkglist">$extras</div>
      <p class="mut" style="margin-top:8px;font-size:12px">Additions over the stock image (persist across reboots and upgrades once committed).</p>
    </div>
    <div class="card"><h2>Scheduled jobs (cron)</h2>
      <pre style="background:none;border:none;padding:0;font:12px/1.6 ui-monospace,Menlo,Consolas,monospace;white-space:pre-wrap;word-break:break-word">$cron_html</pre>
    </div>
  </div>
  <details class="card">
    <summary>Unsaved changes <span class="mut">($unsaved file(s) &mdash; what <span class="mono">nas commit</span> would save)</span></summary>
    <pre class="log">$unsaved_list</pre>
  </details>
  <details class="card">
    <summary>Syslog &mdash; last 100 lines <span class="mut">(newest at the bottom; RAM-only unless <span class="mono">nas logs --persist on</span>)</span></summary>
    <pre class="log">$syslog_html</pre>
  </details>
</main>
<footer>
  <a href="guide.html">User guide</a>
  $ttyd_link
  <a href="status.json">status.json</a>
  <span>Read-only &mdash; manage over SSH with the <span class="mono">nas</span> CLI</span>
</footer>
</body>
</html>
EOF
mv "$WEB/index.html.new" "$WEB/index.html"
# folded-in pages from earlier iterations must not linger in the webroot
rm -f "$WEB/system.html" "$WEB/system.html.new"
