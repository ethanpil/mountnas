#!/bin/sh
# gen-issue — refresh /etc/issue so the console login screen shows how to reach
# the box (its live IPv4 address + mDNS name) BEFORE anyone logs in. Useful on a
# fresh headless install where you don't yet know the DHCP address: attach a
# monitor and the IP is right there above the login prompt.
#
# Writes pure literal text (no getty \-escapes), so it works with busybox getty.
ver=$(cat /usr/share/mountnas/version 2>/dev/null || echo "?")
host=$(hostname 2>/dev/null || echo mountnas)
ips=$(ip -4 -o addr show scope global 2>/dev/null | awk '{sub(/\/.*/,"",$4); print $4}' | paste -sd' ')
{
	# ASCII logo at the top. busybox getty processes backslash escapes in /etc/issue,
	# so double every backslash in the art -> getty renders a single literal '\'.
	if [ -f /usr/share/mountnas/logo ]; then
		sed 's/\\/\\\\/g' /usr/share/mountnas/logo
		printf '                      v %s\n' "$ver"
	fi
	printf '\n  MountNAS %s   (%s.local)\n' "$ver" "$host"
	if [ -n "$ips" ]; then
		printf '  IP: %s\n' "$ips"
		printf '  SSH: ssh root@%s\n' "${ips%% *}"
	else
		printf '  IP: (waiting for network)\n'
	fi
	# RAM floor: the OS + every package unpack into tmpfs on each boot, so low
	# RAM shows up as mysterious failures (full RAM root, OOM) — say it up
	# front, on the screen someone looks at first. 3.4 GB threshold: a real
	# 4 GB box reports ~3.7-4.0 GB MemTotal (firmware/iGPU reservations).
	mem_kb=$(awk '/^MemTotal:/{print $2}' /proc/meminfo 2>/dev/null)
	if [ -n "$mem_kb" ] && [ "$mem_kb" -lt 3500000 ]; then
		printf '  NOTE: only %s MB RAM — 4 GB+ recommended (the OS runs from RAM)\n' "$((mem_kb/1024))"
	fi
	printf '  Console login: root   then run: nas setup\n\n'
} > /etc/issue 2>/dev/null || true
