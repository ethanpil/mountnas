#!/bin/sh
# nas — MountNAS control CLI
set -u
DATA=/mnt/nasdata
CFG=/cfg
STATE=/run/mountnas
BOOTMNT=/media/mnasboot
WBCFG=/usr/libexec/mountnas/write-bootcfg
VERSION=$(cat /usr/share/mountnas/version 2>/dev/null || echo "?")
ok()  { printf '  [ OK ] %s\n' "$*"; }
warn(){ printf '  [WARN] %s\n' "$*"; }
bad() { printf '  [FAIL] %s\n' "$*"; }
confirm() { printf '%s [y/N] ' "$1"; read -r a; [ "$a" = y ] || [ "$a" = Y ]; }
# True if $1 is covered by the read-only 'mountnas-blocked' placeholder that the
# mountnas service mounts over failed data mounts — mountpoint -q alone reports
# that placeholder as a healthy mount.
_blocked() { awk -v m="$1" '$1=="mountnas-blocked" && $2==m{f=1} END{exit !f}' /proc/mounts; }
# Refresh the prompt's unsaved-count cache. Called after every command so the
# PS1 indicator stays current without ever running lbu from the prompt itself.
_refresh_unsaved() { mkdir -p "$STATE"; lbu status 2>/dev/null | grep -c . > "$STATE/unsaved" 2>/dev/null || true; }

cmd_version() { echo "MountNAS $VERSION"; }

cmd_about() {
	[ -f /usr/share/mountnas/logo ] && cat /usr/share/mountnas/logo
	printf '\n                      v %s\n\n' "$VERSION"
	printf 'Diskless Alpine based NAS that runs from RAM off a USB stick.\n\n'
	printf 'http://mountnas.com\n'
}

cmd_help() {
	cat <<EOF
MountNAS $VERSION — control CLI

  nas setup      Guided first-run setup (hostname, network, password, timezone)
  nas status     Health + storage config check (fast, no disk spin-up)
  nas status --deep   …plus SMART, SnapRAID status, time-sync (may wake disks)
  nas disks      Every disk: UUID, mount state, and a paste-ready fstab line
  nas restart    Re-mount disks + (re)start services (no reboot)
  nas commit     Save changes to the USB            (alias: nas save)
  nas backup     Full image of the boot USB to a file  (--to <dir>) — see UPGRADE.md
  nas shutdown   Power off (warns on unsaved changes)
  nas reboot     Reboot   (warns on unsaved changes)
  nas upgrade    Upgrade the OS from a release file or URL — see UPGRADE.md
  nas about      Logo, version, and project info
  nas help / version
  (nas validate = nas status ; nas checkup = nas status --deep)

Important files & paths (edit, then: nas commit):
  /etc/fstab               WHERE YOU CONFIGURE DISKS (add data disks here)
  /mnt/*                   Your data-disk mountpoints ($DATA = system disk)
  /cfg                     Config partition — your saved overlay lives here
  /etc/snapraid.conf       SnapRAID parity array
  mergerfs pool            configured in /etc/fstab (mount options); no separate file
  /etc/samba/smb.conf      Samba shares       (add users: smbpasswd -a <user>)
  /etc/exports             NFS exports
  /etc/docker/daemon.json  Docker             (data-root = $DATA/docker)
  /etc/nut/                UPS: nut.conf, ups.conf, upsd.conf, upsmon.conf
  /etc/smartd.conf         SMART disk-health monitoring + alerts
  /etc/chrony/chrony.conf  Time sync (NTP)
  /etc/ssh/sshd_config     SSH server;  /root/.ssh/authorized_keys = your keys
  /var/lib/zerotier-one    ZeroTier identity + config
  /var/lib/tailscale       Tailscale state
  crontab -e               Scheduled jobs (e.g. SnapRAID sync/scrub)
  Note: /mnt/disk*, /mnt/parity* are CONVENTIONAL names only — SnapRAID cares about
        the paths in snapraid.conf, not these names.

Add a disk:
  1) nas disks                     find the disk + its UUID (copy the fstab line)
  2) edit /etc/fstab, e.g. the system disk (Docker/appdata/backups):
       UUID=<uuid>  $DATA  ext4  rw,noatime,nofail  0 2
  3) nas status                    check the config
  4) nas restart                   mount + start services (no reboot)
  5) nas commit                    persist it

To grant a new user admin rights:  adduser <user> wheel   (then: nas commit)
Nothing persists across reboot until you run 'nas commit'.
EOF
}

# nas status [--deep]
# Fast glance + storage-config validation (all read-only, no disk spin-up).
# --deep adds SMART, SnapRAID status and time-sync — those can wake sleeping disks
# and be slow, so they are opt-in.
cmd_status() {
	deep=0; [ "${1:-}" = "--deep" ] && deep=1

	echo "MountNAS $VERSION  —  $(hostname)  —  up $(cut -d. -f1 /proc/uptime)s"
	ip=$(ip -4 -o addr show scope global 2>/dev/null | awk '{print $4}' | paste -sd' ')
	echo "  IP: ${ip:-none}    RAM: $(free -m | awk '/Mem:/{print $3"/"$2" MB"}')"

	echo "== system =="
	mountpoint -q "$CFG" && ok "config partition mounted ($CFG)" || bad "config partition NOT mounted — saves will be lost"
	case "$(cat $STATE/data 2>/dev/null)" in
		ok)           ok "data disk mounted ($DATA)" ;;
		fresh)        warn "no data disk configured — add to /etc/fstab, then nas commit" ;;
		disconnected) bad "data disk NOT FOUND — check power/cabling" ;;
		mountfail)    bad "data disk failed to mount — check filesystem" ;;
		*)            warn "data disk state unknown" ;;
	esac
	for s in docker samba nfs sshd avahi-daemon; do
		rc-service "$s" status >/dev/null 2>&1 && ok "$s running" || warn "$s not running"
	done
	n=$(lbu status 2>/dev/null | grep -c .)
	[ "${n:-0}" -gt 0 ] && warn "$n unsaved change(s) — run nas commit" || ok "no unsaved changes"
	# last-backup recency (persisted by nas backup: "<epoch> <YYYY-mm-dd HH:MM>")
	lbk=$(cat /etc/mountnas/last-backup 2>/dev/null || true)
	case "${lbk%% *}" in
		'') warn "no 'nas backup' recorded yet — see UPGRADE.md" ;;
		*[!0-9]*) ok "last backup: $lbk" ;;
		*) ok "last backup: ${lbk#* } ($(( ( $(date +%s) - ${lbk%% *} ) / 86400 )) day(s) ago)" ;;
	esac

	echo "== storage config (fstab) =="
	# per data mount
	awk '$1!~/^#/ && $2 ~ /^\/mnt\//{print $1" "$2" "$4}' /etc/fstab | while read -r spec mp opts; do
		case "$spec" in UUID=*|LABEL=*)
			findfs "$spec" >/dev/null 2>&1 && ok "$mp: $spec resolves" || bad "$mp: $spec NOT FOUND" ;;
		esac
		echo "$opts" | grep -q nofail && ok "$mp: nofail present" || warn "$mp: missing nofail (a missing disk could hang boot)"
		if _blocked "$mp"; then bad "$mp: BLOCKED (disk missing/failed — ro placeholder mounted)"
		elif mountpoint -q "$mp"; then ok "$mp: mounted"
		else warn "$mp: declared but not mounted"; fi
	done
	# duplicates
	dupu=$(awk '$1~/^UUID=/ && $2!~/^#/{print $1}' /etc/fstab | sort | uniq -d)
	[ -n "$dupu" ] && bad "duplicate UUID in fstab: $dupu"
	dupm=$(awk '$1!~/^#/ && $2 ~ /^\/(cfg|mnt)/{print $2}' /etc/fstab | sort | uniq -d)
	[ -n "$dupm" ] && bad "duplicate mountpoint in fstab: $dupm"
	# docker data-root: config points under $DATA, but only OK once the disk is mounted
	dr=$(awk -F'"' '/data-root/{print $4}' /etc/docker/daemon.json 2>/dev/null)
	if [ -n "$dr" ]; then
		if [ "${dr#"$DATA"}" != "$dr" ]; then
			[ "$(cat $STATE/data 2>/dev/null)" = ok ] \
				&& ok "Docker data-root under $DATA" \
				|| warn "Docker data-root configured for $DATA (disk not mounted yet)"
		else bad "Docker data-root ($dr) NOT under $DATA"; fi
	fi
	# no data path tracked
	grep -qE "^(/?mnt/nasdata|/?mnt/disk|/?mnt/parity)" /etc/lbu/include 2>/dev/null \
		&& bad "a data path is in /etc/lbu/include (commit would copy your disk!)" \
		|| ok "lbu include has no data paths"
	# share paths must be live mountpoints
	# NB: the walk always ends at a mountpoint — "/" itself is one (the RAM root),
	# and the ro placeholder is one too. Only a non-root, non-placeholder mount
	# means the path really lands on a disk.
	awk -F= '/^[[:space:]]*path[[:space:]]*=/{gsub(/[[:space:]]/,"",$2);print $2}' /etc/samba/smb.conf 2>/dev/null | while read -r p; do
		[ -z "$p" ] && continue
		td=$p; while [ "$td" != "/" ] && ! mountpoint -q "$td"; do td=$(dirname "$td"); done
		if _blocked "$td"; then bad "samba path $p is BLOCKED (disk missing/failed)"
		elif [ "$td" != "/" ] && mountpoint -q "$td"; then ok "samba path $p on a mounted fs"
		else bad "samba path $p is on RAM (no disk mounted)"; fi
	done
	[ -f /etc/exports ] && awk '/^\//{print $1}' /etc/exports | while read -r p; do
		td=$p; while [ "$td" != "/" ] && ! mountpoint -q "$td"; do td=$(dirname "$td"); done
		if _blocked "$td"; then bad "nfs export $p is BLOCKED (disk missing/failed)"
		elif [ "$td" != "/" ] && mountpoint -q "$td"; then ok "nfs export $p on a mounted fs"
		else bad "nfs export $p is on RAM (no disk mounted)"; fi
	done
	# snapraid parity sizing (best-effort)
	if grep -q '^data ' /etc/snapraid.conf 2>/dev/null; then
		maxd=$(awk '/^data /{print $3}' /etc/snapraid.conf | while read -r d; do df -k "$d" 2>/dev/null|awk 'NR==2{print $2}'; done | sort -n | tail -1)
		par=$(awk '/^parity /{print $2}' /etc/snapraid.conf | sed 's#/[^/]*$##')
		[ -n "$par" ] && { ps=$(df -k "$par" 2>/dev/null|awk 'NR==2{print $2}')
			[ -n "$ps" ] && [ -n "$maxd" ] && { [ "$ps" -ge "$maxd" ] && ok "SnapRAID parity >= largest data disk" || bad "SnapRAID parity SMALLER than largest data disk"; }; }
	fi
	# data services must NOT be in a runlevel — mountnas owns them. A user who runs
	# 'rc-update add docker default' would start Docker before the disk mounts.
	for s in docker samba nfs; do
		if rc-update show 2>/dev/null | grep -qE "^\s*$s\b"; then
			bad "$s is in a runlevel — mountnas must own it. Remove: rc-update del $s default"
		else ok "$s not in a runlevel (managed by mountnas)"; fi
	done

	if [ "$deep" = 1 ]; then
		echo "== deep: hardware / runtime =="
		df -h / 2>/dev/null | awk 'NR==2{print "  root (RAM) used: "$5}'
		for d in $(lsblk -dno NAME,TYPE | awk '$2=="disk"{print $1}'); do
			h=$(smartctl -H "/dev/$d" 2>/dev/null | awk -F: '/overall-health/{gsub(/ /,"",$2);print $2}')
			[ -n "$h" ] && { [ "$h" = PASSED ] && ok "/dev/$d SMART PASSED" || bad "/dev/$d SMART $h"; }
		done
		command -v snapraid >/dev/null 2>&1 && grep -q '^data ' /etc/snapraid.conf 2>/dev/null && \
			snapraid status 2>/dev/null | grep -iE 'days|sync|scrub' | sed 's/^/  /'
		chronyc tracking >/dev/null 2>&1 && ok "time sync active" || warn "time not synced"
	else
		printf "  Tip: 'nas status --deep' adds SMART / SnapRAID / time-sync (may wake sleeping disks).\n"
	fi
	return 0
}

# nas disks — every disk with UUID + mount state, marking the boot USB / cfg
# partition, plus a paste-ready fstab line for each unconfigured data partition.
cmd_disks() {
	bp=$(findfs LABEL=BOOT 2>/dev/null)
	usb=$(lsblk -no pkname "$bp" 2>/dev/null | head -n1)

	echo "Detected disks (* = MountNAS boot USB — do NOT add to fstab):"
	printf "  %-8s %-7s %-8s %-20s %s\n" NAME SIZE FSTYPE MOUNTPOINT UUID
	# Pairs mode (-P): KEY="value" per line, so empty fields (e.g. an unlabelled
	# data partition) don't shift columns the way raw mode + read collapses them.
	lsblk -Pno NAME,TYPE,SIZE,FSTYPE,LABEL,UUID,MOUNTPOINT 2>/dev/null | while read -r line; do
		eval "$line"
		case "$TYPE" in disk|part) ;; *) continue ;; esac
		tag=""
		[ "$NAME" = "$usb" ] && tag=" *"
		[ "$LABEL" = BOOT ]  && tag=" * (BOOT)"
		[ "$LABEL" = MNASCFG ] && tag=" * (cfg)"
		printf "  %-8s %-7s %-8s %-20s %s%s\n" "$NAME" "$SIZE" "${FSTYPE:--}" "${MOUNTPOINT:-(not mounted)}" "${UUID:--}" "$tag"
	done

	echo
	echo "Configured in /etc/fstab:"
	awk '$1!~/^#/ && $2 ~ /^(\/cfg|\/mnt\/)/ {printf "  %-14s %s\n",$2,$1}' /etc/fstab

	echo
	echo "Paste-ready fstab line(s) for unconfigured data partitions:"
	# Build in a subshell-captured var: the while loop below runs in a pipe subshell,
	# so a flag set inside it would not survive — check the captured output instead.
	# Suggested mountpoints: /mnt/nasdata first (only if not already in fstab),
	# then /mnt/disk1, /mnt/disk2, … — never the same mountpoint twice.
	have_nd=$(awk '$1!~/^#/ && $2=="/mnt/nasdata"{f=1} END{print f+0}' /etc/fstab)
	lines=$(lsblk -Pno NAME,TYPE,FSTYPE,LABEL,UUID 2>/dev/null | { n=1; while read -r line; do
		eval "$line"
		[ "$TYPE" = part ] || continue
		[ -n "$UUID" ] && [ -n "$FSTYPE" ] || continue
		case "$LABEL" in BOOT|MNASCFG) continue ;; esac
		[ "$NAME" = "$usb" ] && continue
		# already referenced in fstab (by UUID or by device)?
		grep -q "$UUID" /etc/fstab 2>/dev/null && continue
		if [ "$have_nd" = 0 ]; then mp=/mnt/nasdata; have_nd=1
		else
			while awk -v m="/mnt/disk$n" '$1!~/^#/ && $2==m{f=1} END{exit !f}' /etc/fstab; do n=$((n+1)); done
			mp="/mnt/disk$n"; n=$((n+1))
		fi
		printf "  UUID=%s  %-13s %s  rw,noatime,nofail  0 2   # paste into /etc/fstab (edit mountpoint)\n" "$UUID" "$mp" "$FSTYPE"
	done; })
	[ -n "$lines" ] && printf '%s\n' "$lines" \
		|| echo "  (none — every filesystem is already in fstab, or blank/unformatted)"
	echo "  Tip: the system disk uses /mnt/nasdata; extra data/parity disks use any path"
	echo "       you like (the /mnt/disk1, /mnt/parity1 names are just a convention)."
}

cmd_restart() {
	# Re-run the storage supervisor: re-mount data disks and (re)start
	# docker/samba/nfs, without rebooting. Handy after editing /etc/fstab.
	rc-service mountnas restart
}

cmd_commit() {
	mountpoint -q "$CFG" || { bad "config partition ($CFG) not mounted — refusing (would save to RAM)"; return 1; }
	grep -qE "^(/?mnt/nasdata|/?mnt/disk|/?mnt/parity)" /etc/lbu/include 2>/dev/null \
		&& { bad "a data path is in /etc/lbu/include — refusing (would tar your data disk)"; return 1; }
	echo "Saving configuration..."
	lbu commit -v || { bad "lbu commit failed"; return 1; }
	sz=$(du -k "$CFG"/*.apkovl.tar.gz 2>/dev/null | awk '{s+=$1}END{print s}')
	[ "${sz:-0}" -gt 51200 ] && warn "overlay is large (${sz}KB) — a big file in a tracked path (e.g. /root)?"
	ok "saved to $CFG"
}

# Full image of the WHOLE boot USB (OS + config partition) to a gzip file. This
# is the rollback net for 'nas upgrade': restore = write the image back to a
# USB and boot it. Reading the device while running is safe (dd/gzip only reads);
# we briefly remount /cfg read-only so its filesystem is quiescent in the image.
cmd_backup() {
	dest=""; [ "${1:-}" = "--to" ] && dest="${2:-}"
	cat <<EOF
  Note: this images the BOOT USB (the OS + your saved config on MNASCFG).
  It does NOT back up your data disks or Docker data — those live on
  separate storage and are not part of this image.
EOF
	bp=$(findfs LABEL=BOOT 2>/dev/null)
	[ -n "$bp" ] || { bad "cannot find the BOOT partition"; return 1; }
	disk=$(lsblk -no pkname "$bp" 2>/dev/null | head -n1)
	[ -n "$disk" ] || { bad "cannot determine the USB device for $bp"; return 1; }
	dev="/dev/$disk"
	if [ -z "$dest" ]; then
		mountpoint -q "$DATA" || { bad "data disk not mounted — give a target: nas backup --to <dir|file>"; return 1; }
		dest="$DATA/backups"; mkdir -p "$dest"
	fi
	if [ -d "$dest" ]; then out="$dest/mountnas-backup-$(hostname)-$(date +%Y%m%d-%H%M%S).img.gz"; else out="$dest"; fi
	sz=$(lsblk -bdno SIZE "$dev" 2>/dev/null)
	echo "Imaging $dev (~$(( ${sz:-0} /1048576)) MB) -> $out"
	echo "This can take several minutes; the image compresses (mostly-empty space shrinks away)."
	mkdir -p "$STATE" 2>/dev/null || true
	sync; mount -o remount,ro "$CFG" 2>/dev/null || true
	# pv gives a progress bar + ETA when available. Both stages must be checked:
	# if pv hits a read error mid-device, gzip still exits 0 on the truncated
	# stream — so pv drops a marker file on failure.
	if command -v pv >/dev/null 2>&1; then
		rm -f "$STATE/pv.err"
		{ pv "$dev" || : > "$STATE/pv.err"; } | gzip -c > "$out" && [ ! -f "$STATE/pv.err" ] && rc=0 || rc=1
		rm -f "$STATE/pv.err"
	else
		gzip -c < "$dev" > "$out" && rc=0 || rc=1
	fi
	if [ "$rc" = 0 ]; then
		mount -o remount,rw "$CFG" 2>/dev/null || true; sync
		ok "backup written: $out"
		date '+%Y-%m-%d %H:%M' > "$STATE/last-backup" 2>/dev/null || true
		# persistent copy ("<epoch> <date>") so 'nas status' and the upgrade gate
		# can report backup age across reboots (saved with the next commit)
		mkdir -p /etc/mountnas 2>/dev/null || true
		printf '%s %s\n' "$(date +%s)" "$(date '+%Y-%m-%d %H:%M')" > /etc/mountnas/last-backup 2>/dev/null || true
		warn "COPY THIS FILE TO ANOTHER COMPUTER — a backup stored only on this box can't save a dead box."
	else
		mount -o remount,rw "$CFG" 2>/dev/null || true
		bad "backup failed (out of space?): $out"; rm -f "$out" 2>/dev/null; return 1
	fi
}

_power() { act="$1"; word="$2"
	n=$(lbu status 2>/dev/null | grep -c .)
	if [ "${n:-0}" -gt 0 ]; then
		echo "You have $n unsaved change(s)."
		printf 'Before %s: [S]ave / [D]iscard / [C]ancel: ' "$word"; read -r a
		case "$a" in S|s) cmd_commit || return 1 ;; D|d) : ;; *) echo "Cancelled."; return 1 ;; esac
	fi
	# $act is always an absolute path (/sbin/poweroff|/sbin/reboot). exec of a
	# pathname bypasses shell aliases/functions, and this script is non-interactive
	# (never sources /etc/profile), so the reboot/poweroff aliases don't exist here
	# anyway — no recursion back into 'nas'. Quoted for hygiene.
	exec "$act"
}
cmd_shutdown() { _power "/sbin/poweroff" "shutdown"; }
cmd_reboot()   { _power "/sbin/reboot"   "reboot"; }

# First real wired NIC (skips virtual + wireless), mirroring mountnas-net's list.
_pick_nic() {
	for path in /sys/class/net/*; do
		n=$(basename "$path")
		case "$n" in lo|veth*|docker*|br-*|virbr*|tap*|tun*|zt*|tailscale*|wg*|bond*|dummy*) continue ;; esac
		[ -e "$path/wireless" ] && continue
		printf '%s\n' "$n"; return 0
	done
}

cmd_setup() {
	echo "=== MountNAS first-run setup ==="

	cur=$(hostname 2>/dev/null || echo mountnas)
	printf '[1/5] Hostname [%s]: ' "$cur"; read -r hn
	[ -n "$hn" ] || hn="$cur"
	case "$hn" in
		*[!A-Za-z0-9-]*) warn "invalid hostname '$hn' (letters, digits, hyphen only) — kept $cur"; hn="$cur" ;;
	esac
	printf '%s\n' "$hn" > /etc/hostname; hostname "$hn" 2>/dev/null; ok "hostname set to $hn"

	echo "[2/5] Root password"; passwd
	# Set the timezone directly from the baked-in tzdata. We deliberately do NOT use
	# setup-timezone: it runs 'apk add tzdata', which fails offline (this appliance
	# has no internet repo and the on-media repo is not always mounted). tzdata ships
	# in the image, so /usr/share/zoneinfo/<tz> already exists.
	printf '[3/5] Timezone (e.g. America/New_York), blank to skip: '; read -r tz
	if [ -n "$tz" ]; then
		if [ -f "/usr/share/zoneinfo/$tz" ]; then
			cp "/usr/share/zoneinfo/$tz" /etc/localtime && printf '%s\n' "$tz" > /etc/timezone
			ok "timezone set to $tz"
		else
			warn "unknown timezone '$tz' — skipped (list them with: ls /usr/share/zoneinfo)"
		fi
	fi
	# Network: DHCP (default) leaves the mountnas-net first-boot handler to configure
	# the wired NIC. Static rewrites /etc/network/interfaces (lo + a static stanza),
	# which makes mountnas-net stand down (it only acts when no non-lo iface exists).
	printf '[4/5] Network: [D]HCP (default) / [S]tatic: '; read -r net
	case "$net" in
		S|s)
			nic=$(_pick_nic); [ -n "$nic" ] || nic=eth0
			printf '  Interface [%s]: ' "$nic"; read -r i; [ -n "$i" ] && nic="$i"
			printf '  IP address with prefix (e.g. 192.168.1.50/24): '; read -r addr
			printf '  Gateway (e.g. 192.168.1.1): '; read -r gw
			printf '  DNS server(s), space-separated (e.g. 1.1.1.1 8.8.8.8): '; read -r dns
			if [ -n "$addr" ]; then
				{
					printf 'auto lo\niface lo inet loopback\n'
					printf '\nauto %s\n' "$nic"
					printf 'iface %s inet static\n' "$nic"
					printf '    address %s\n' "$addr"
					[ -n "$gw" ] && printf '    gateway %s\n' "$gw"
				} > /etc/network/interfaces
				if [ -n "$dns" ]; then
					: > /etc/resolv.conf
					for d in $dns; do printf 'nameserver %s\n' "$d" >> /etc/resolv.conf; done
				fi
				ok "static network set on $nic ($addr)"
				if confirm "  Apply it now? (restarts networking — an SSH session may drop)"; then
					rc-service networking restart >/dev/null 2>&1 \
						&& ok "networking restarted with the new address" \
						|| warn "networking restart failed — settings apply on next reboot"
				else
					echo "  It will apply on the next reboot."
				fi
			else
				warn "no IP entered — left networking on DHCP"
			fi
			;;
		*) ok "using DHCP (auto-configured at boot)" ;;
	esac

	# Mark setup as completed so the first-login auto-run (profile.d/nas-welcome.sh)
	# stops offering the wizard. Written before the commit so it persists with it.
	mkdir -p /etc/mountnas
	date '+%Y-%m-%d %H:%M' > /etc/mountnas/setup-done

	echo "[5/5] Saving..."; cmd_commit
	cat <<EOF

Setup complete. NEXT: add your data disk(s).
  1) nas disks                              (find your disk + its UUID)
  2) (blank disk?) mkfs.ext4 -L nasdata /dev/sdX
  3) edit /etc/fstab, add the system disk:
       UUID=<uuid>  /mnt/nasdata  ext4  rw,noatime,nofail  0 2
  4) nas status          (check it)
  5) rc-service mountnas restart    (mounts + starts services, no reboot)
  6) nas commit
EOF
}

# ---------- upgrade (single-slot, in-place; full detail in UPGRADE.md) ----------
_mount_boot_rw() {
	mkdir -p "$BOOTMNT"
	mountpoint -q "$BOOTMNT" || mount LABEL=BOOT "$BOOTMNT" 2>/dev/null || { bad "cannot mount BOOT partition"; return 1; }
	mount -o remount,rw "$BOOTMNT" 2>/dev/null || true
	[ -f "$BOOTMNT/.nas-boot" ] || { bad "BOOT partition missing .nas-boot marker — refusing"; return 1; }
}

# nas upgrade <mountnas-*.img.gz>
# Overwrites the OS on the boot USB in place, then you reboot. The live modloop is
# busy (loop-mounted), so we free it first with copy-modloop (official Alpine tool:
# copies modules to RAM, unmounts the loopback) — after that the modloop file can be
# rewritten safely. Config (/cfg) and data disks are never touched.
cmd_upgrade() {
	img="${1:-}"; url=""; dlf=""
	[ -n "$img" ] || { echo "usage: nas upgrade <mountnas-*.img.gz | https://.../mountnas-*.img.gz>   (see UPGRADE.md)"; return 1; }
	case "$img" in
		http://*|https://*) url="$img" ;;
		*) [ -f "$img" ] || { bad "not found: $img"; return 1; } ;;
	esac
	command -v copy-modloop >/dev/null 2>&1 || { bad "copy-modloop not found (alpine-conf) — cannot upgrade safely"; return 1; }

	# ---- warning + backup gate ----
	cat <<EOF

  ========================= UPGRADE WARNING =========================
  This rewrites the OS on the boot USB. If it fails, this box may not
  boot again.
    * FIRST run:  nas backup   — it images this USB to a file. COPY that
      file to ANOTHER computer (not this box).
    * Recover a failed upgrade by writing that image to a DIFFERENT USB
      and booting from it.
    * NEVER boot with two MountNAS USB drives attached at once
      (duplicate disk labels will collide).
  ===================================================================
EOF
	lb=$(cat "$STATE/last-backup" 2>/dev/null || true)
	[ -n "$lb" ] && echo "  Last 'nas backup' this session: $lb" || echo "  No 'nas backup' recorded this session."
	plb=$(cat /etc/mountnas/last-backup 2>/dev/null || true)
	[ -n "$plb" ] && [ -z "$lb" ] && echo "  Last recorded 'nas backup' (earlier session): ${plb#* }"
	printf '  Type YES (uppercase) to confirm you have a backup and continue: '
	read -r a; [ "$a" = YES ] || { echo "Aborted — no changes made."; return 1; }

	_mount_boot_rw || return 1

	# ---- choose temp space and pre-check it fits the decompressed image ----
	# Work in KiB with df -Pk so this holds under both busybox and coreutils df.
	tmp="${TMPDIR:-}"
	[ -n "$tmp" ] || { mountpoint -q "$DATA" && tmp="$DATA" || { bad "no temp space: data disk not mounted. Mount it or set TMPDIR=<disk dir>."; return 1; }; }
	case "$img" in
		*.gz) need_kb=7340032 ;;   # ~7 GiB: image is 6 GiB; gzip -l is unreliable >4 GiB
		*)    need_kb=$(( ( $(stat -c %s "$img" 2>/dev/null || echo 6442450944) / 1024 ) + 262144 )) ;;
	esac
	[ -n "$url" ] && need_kb=$((need_kb + 2097152))   # + ~2 GiB for the downloaded .img.gz
	avail_kb=$(df -Pk "$tmp" 2>/dev/null | awk 'NR==2{print $4}')
	if [ -z "$avail_kb" ] || [ "$avail_kb" -lt "$need_kb" ]; then
		bad "not enough free space in $tmp to unpack the image."
		bad "need ~$((need_kb/1024)) MB, have ~$(( ${avail_kb:-0} /1024)) MB. Free space or set TMPDIR=<bigger dir>."
		return 1
	fi

	# ---- URL: download into temp space, verify against SHA256SUMS if published ----
	if [ -n "$url" ]; then
		dlf="$tmp/.nas-upgrade.$$.${url##*/}"
		echo "Downloading $url ..."
		if command -v curl >/dev/null 2>&1; then curl -fL -o "$dlf" "$url"
		else wget -O "$dlf" "$url"; fi \
			|| { bad "download failed"; rm -f "$dlf"; return 1; }
		# a GitHub release publishes SHA256SUMS next to the image — verify when found
		sums=$( { command -v curl >/dev/null 2>&1 && curl -fsL "${url%/*}/SHA256SUMS" \
			|| wget -qO- "${url%/*}/SHA256SUMS"; } 2>/dev/null || true)
		want=$(printf '%s\n' "$sums" | awk -v f="${url##*/}" '$2==f{print $1}')
		if [ -n "$want" ]; then
			got=$(sha256sum "$dlf" | awk '{print $1}')
			[ "$got" = "$want" ] && ok "checksum verified against SHA256SUMS" \
				|| { bad "checksum MISMATCH — refusing this download"; rm -f "$dlf"; return 1; }
		else
			warn "no SHA256SUMS found next to the URL — skipping checksum verification"
		fi
		img="$dlf"
	fi

	# ---- unpack + loop-mount the image's BOOT partition (p1) ----
	raw="$tmp/.nas-upgrade.$$.img"; m=$(mktemp -d); loop=""
	_cleanup() { [ -n "$loop" ] && losetup -d "$loop" 2>/dev/null; rm -f "$raw"; [ -n "$dlf" ] && rm -f "$dlf"; rmdir "$m" 2>/dev/null; }
	echo "Unpacking image into $tmp ..."
	case "$img" in
		*.gz)
			# pv shows unpack progress when available; gzip -dc itself still
			# detects a truncated/corrupt stream, so no extra status capture.
			if command -v pv >/dev/null 2>&1; then pv "$img" | gzip -dc > "$raw"
			else gzip -dc "$img" > "$raw"; fi \
				|| { bad "decompress failed"; _cleanup; return 1; } ;;
		*)    cp "$img" "$raw" || { bad "copy failed"; _cleanup; return 1; } ;;
	esac
	# the downloaded .gz is no longer needed once unpacked — free the space now
	[ -n "$dlf" ] && { rm -f "$dlf"; dlf=""; }
	loop=$(losetup -fP --show "$raw") || { bad "losetup failed"; _cleanup; return 1; }
	mount -o ro "${loop}p1" "$m" 2>/dev/null || { bad "cannot mount the image's BOOT partition"; _cleanup; return 1; }
	for f in boot/vmlinuz-lts boot/initramfs-lts boot/modloop-lts; do
		[ -f "$m/$f" ] || { bad "image is missing $f — not a MountNAS image?"; umount "$m"; _cleanup; return 1; }
	done

	# ---- free the live modloop so we can overwrite it in place (official tool) ----
	echo "Freeing the live modloop (copy-modloop) ..."
	umount "$STATE/apks" 2>/dev/null || true   # release the mountnas bind on $BOOTMNT/apks
	copy-modloop || { bad "copy-modloop failed — aborting (nothing on the USB was changed yet)"; umount "$m"; _cleanup; return 1; }

	# ---- overwrite boot files in place, crash-safe (temp name -> rename) ----
	echo "Writing the new system to the USB ..."
	cp "$BOOTMNT/world.base" "$STATE/old.world.base" 2>/dev/null || true
	ec=0
	for f in vmlinuz-lts initramfs-lts modloop-lts; do
		{ cp "$m/boot/$f" "$BOOTMNT/boot/.$f.new" && mv "$BOOTMNT/boot/.$f.new" "$BOOTMNT/boot/$f"; } || ec=1
	done
	# Swap in the new apks repo ONLY if the copy fully succeeded — a failed/partial
	# copy must leave the known-good repo untouched, never replace it.
	rm -rf "$BOOTMNT/apks.new"; mkdir -p "$BOOTMNT/apks.new"
	if cp -r "$m"/apks/. "$BOOTMNT/apks.new/"; then
		rm -rf "$BOOTMNT/apks.old"; mv "$BOOTMNT/apks" "$BOOTMNT/apks.old" 2>/dev/null
		mv "$BOOTMNT/apks.new" "$BOOTMNT/apks" || ec=1
		rm -rf "$BOOTMNT/apks.old"
	else
		rm -rf "$BOOTMNT/apks.new"; ec=1
	fi
	if [ -f "$m/world.base" ]; then { cp "$m/world.base" "$BOOTMNT/.world.base.new" && mv "$BOOTMNT/.world.base.new" "$BOOTMNT/world.base"; } || ec=1; fi
	umount "$m"; _cleanup
	[ "$ec" = 0 ] || { bad "some files failed to write — RESTORE YOUR BACKUP before rebooting."; return 1; }

	# ---- reconcile /etc/apk/world (preserve user-added pkgs across the version bump) ----
	# extras = current world - the OLD release's base ; new world = NEW base ∪ extras.
	# The next boot installs this world from the new on-USB apks repo. awk (not comm)
	# so we need no sorted input and no extra binary.
	new_wb="$BOOTMNT/world.base"; old_wb="$STATE/old.world.base"
	if [ -f "$new_wb" ]; then
		if [ -f "$old_wb" ]; then
			awk 'NR==FNR{a[$1];next} !($1 in a)' "$old_wb" /etc/apk/world > "$STATE/extras.$$"
			cat "$new_wb" "$STATE/extras.$$" | sort -u > "$STATE/desired.$$"
		else
			cat "$new_wb" /etc/apk/world | sort -u > "$STATE/desired.$$"
			warn "previous world.base missing — can't drop removed packages this upgrade"
		fi
		cp "$STATE/desired.$$" /etc/apk/world
		rm -f "$STATE/extras.$$" "$STATE/desired.$$"
	fi

	# ---- regenerate the (single-slot) bootloader config + persist config ----
	"$WBCFG" "$BOOTMNT"; sync
	cmd_commit

	cat <<EOF

  [ OK ] Upgrade written successfully. Config and data are untouched.
         Reboot to run the new version:   nas reboot
         If the new version misbehaves, restore your 'nas backup' image
         to another USB and boot from it.
EOF
}

case "${1:-help}" in
	setup) cmd_setup ;;
	status) shift; cmd_status "$@" ;;
	disks) cmd_disks ;;
	validate) shift; cmd_status "$@" ;;
	checkup) cmd_status --deep ;;
	restart) cmd_restart ;;
	commit|save) cmd_commit ;;
	backup) shift; cmd_backup "$@" ;;
	shutdown) cmd_shutdown ;;
	reboot) cmd_reboot ;;
	upgrade) shift; cmd_upgrade "$@" ;;
	version) cmd_version ;;
	about) cmd_about ;;
	help|--help|-h) cmd_help ;;
	*) echo "unknown command: $1"; echo; cmd_help; exit 1 ;;
esac

# Keep the prompt's [unsaved:N] indicator current after any command that may have
# changed state (e.g. commit zeroes it). Commands that exec (shutdown/reboot) never
# reach here, which is fine — the box is on its way down.
_refresh_unsaved
