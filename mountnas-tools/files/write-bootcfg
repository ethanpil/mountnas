#!/bin/sh
# write-bootcfg <bootmnt>
# Single-slot: one bootable system on the BOOT partition (/boot + /apks). Writes
# both a BIOS (syslinux) and a UEFI (grub) config pointing at it.
set -eu
B="$1"
# cmdline.base is written to the BOOT partition at build time from the repo's
# single source (scripts/cmdline.base). No baked-in fallback here on purpose:
# silently booting a possibly-stale cmdline is worse than refusing — a missing
# cmdline.base means the BOOT partition is damaged or not a MountNAS layout.
BASE=$(cat "$B/cmdline.base") \
  || { echo "write-bootcfg: FATAL: $B/cmdline.base missing — refusing to guess the kernel cmdline" >&2; exit 1; }
# modloop path is resolved relative to the boot media by the init. The apk repo is
# found via the .boot_repository marker (alpine_repo=auto) — a literal path would be
# used verbatim and disable that discovery.
APPEND="$BASE modloop=/boot/modloop-lts alpine_repo=auto"

# Early CPU microcode: prepend the vendor ucode images when the media carries
# them (fetched as boot_addons in mkimg.nas.sh; the CPU loads only its own
# vendor's blob). Media written by an older build simply lacks the files and
# the initrd line comes out plain — no error, no stale reference.
UCODE=""
for u in amd-ucode.img intel-ucode.img; do
	[ -f "$B/boot/$u" ] && UCODE="$UCODE /boot/$u"
done
UCODE="${UCODE# }"

# BIOS / syslinux
{
	echo "SERIAL 0 115200"; echo "PROMPT 1"; echo "TIMEOUT 30"; echo "DEFAULT mountnas"; echo
	echo "LABEL mountnas"
	echo "  MENU LABEL MountNAS"
	echo "  KERNEL /boot/vmlinuz-lts"
	if [ -n "$UCODE" ]; then
		# syslinux takes multiple initrds comma-separated; microcode must be first
		echo "  INITRD $(printf '%s' "$UCODE" | tr ' ' ','),/boot/initramfs-lts"
	else
		echo "  INITRD /boot/initramfs-lts"
	fi
	echo "  APPEND $APPEND"
} > "$B/syslinux.cfg"
mkdir -p "$B/boot/syslinux"; cp "$B/syslinux.cfg" "$B/boot/syslinux/syslinux.cfg" 2>/dev/null || true

# UEFI / grub
mkdir -p "$B/boot/grub"
{
	# grub timeout is in SECONDS; syslinux TIMEOUT above is in 1/10 s. Both 3 s.
	echo "set timeout=3"; echo "set default=0"
	echo "menuentry \"MountNAS\" {"
	echo "  linux /boot/vmlinuz-lts $APPEND"
	# grub takes multiple initrd args space-separated; microcode must be first
	echo "  initrd ${UCODE:+$UCODE }/boot/initramfs-lts"
	echo "}"
} > "$B/boot/grub/grub.cfg"
sync
