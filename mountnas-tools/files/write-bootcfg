#!/bin/sh
# write-bootcfg <bootmnt>
# Single-slot: one bootable system on the BOOT partition (/boot + /apks). Writes
# both a BIOS (syslinux) and a UEFI (grub) config pointing at it.
set -eu
B="$1"
BASE=$(cat "$B/cmdline.base" 2>/dev/null || echo \
  "modules=loop,squashfs,sd-mod,usb-storage,vfat,ext4,ahci,nvme,virtio_pci,virtio_scsi,virtio_blk console=tty1 console=ttyS0,115200 ovl_dev=LABEL=MNASCFG")
# modloop path is resolved relative to the boot media by the init. The apk repo is
# found via the .boot_repository marker (alpine_repo=auto) — a literal path would be
# used verbatim and disable that discovery.
APPEND="$BASE modloop=/boot/modloop-lts alpine_repo=auto"

# BIOS / syslinux
{
	echo "SERIAL 0 115200"; echo "PROMPT 1"; echo "TIMEOUT 30"; echo "DEFAULT mountnas"; echo
	echo "LABEL mountnas"
	echo "  MENU LABEL MountNAS"
	echo "  KERNEL /boot/vmlinuz-lts"
	echo "  INITRD /boot/initramfs-lts"
	echo "  APPEND $APPEND"
} > "$B/syslinux.cfg"
mkdir -p "$B/boot/syslinux"; cp "$B/syslinux.cfg" "$B/boot/syslinux/syslinux.cfg" 2>/dev/null || true

# UEFI / grub
mkdir -p "$B/boot/grub"
{
	echo "set timeout=30"; echo "set default=0"
	echo "menuentry \"MountNAS\" {"
	echo "  linux /boot/vmlinuz-lts $APPEND"
	echo "  initrd /boot/initramfs-lts"
	echo "}"
} > "$B/boot/grub/grub.cfg"
sync
