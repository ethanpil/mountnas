#compdef nas
# zsh completion for the nas CLI (installed to /usr/share/zsh/site-functions/_nas,
# which is in zsh's default fpath — active for users running compinit).
# Command list: keep in sync with the dispatcher in files/nas AND the bash
# completion (files/bash-nas-completion.sh).
local -a cmds
cmds=(setup status disks restart changes changed commit save rollback backup logs web history notify report shutdown reboot upgrade version about help)
if (( CURRENT == 2 )); then
	_describe "nas command" cmds
else
	case "$words[2]" in
		status)          _values flag --deep --json ;;
		disks)           _values flag --json ;;
		changes|changed) _values flag --diff ;;
		commit|save)     _values flag -m ;;
		rollback)        _values flag --list ;;
		logs)            _values flag -f -n --persist ;;
		web)             _values action on off status ;;
		history)         _values flag -n --all ;;
		notify)          _values flag --test ;;
		upgrade)         _values flag --check --yes ;;
		reboot|shutdown) _values flag --yes --save ;;
	esac
fi
