# Maintainer: MountNAS <ethan@piliavin.com>
pkgname=mountnas-tools
pkgver=1.0.0
pkgrel=0
# The release TAG as users know it (alpha-7, v1.2, ...). pkgver must satisfy
# apk's version grammar, so tags like alpha-7 cannot BE the pkgver — the
# workflow seds the real tag in here and the tools display it, while
# /usr/share/mountnas/version keeps the apk pkgver (the CI upgrade test and
# apk itself rely on that one).
_reltag=dev
pkgdesc="MountNAS CLI, storage supervisor, and helpers"
url="https://github.com/ethanpil/mountnas"
# Logically noarch (pure scripts), but built as x86_64 so the file lands in the
# local repo's x86_64/ dir where apk/mkimage look — a local abuild repo has no
# noarch/ subdir, and apk resolves a noarch package's file from <repo>/noarch/.
arch="x86_64"
license="MIT"
depends="alpine-conf util-linux e2fsprogs smartmontools openrc busybox
	docker samba nfs-utils"
options="!check"
source=""

# No sources to fetch/compile; this package only installs the files under
# ./files. We read them from $startdir (the APKBUILD's dir), NOT $srcdir, because
# abuild WIPES $srcdir (==$startdir/src) during its clean phase — that is exactly
# why the files live in files/ and not src/. builddir points at $startdir so the
# prepare/build phases have an existing dir to cd into; build itself is a no-op.
builddir="$startdir"
build() { :; }

package() {
	install -Dm755 "$startdir"/files/nas           "$pkgdir"/usr/sbin/nas
	install -Dm755 "$startdir"/files/mountnas       "$pkgdir"/etc/init.d/mountnas
	install -Dm755 "$startdir"/files/mountnas-mkdirs "$pkgdir"/etc/init.d/mountnas-mkdirs
	install -Dm755 "$startdir"/files/mountnas-net   "$pkgdir"/etc/init.d/mountnas-net
	install -Dm755 "$startdir"/files/mountnas-sshkey "$pkgdir"/etc/init.d/mountnas-sshkey
	install -Dm755 "$startdir"/files/mountnas-issue  "$pkgdir"/etc/init.d/mountnas-issue
	install -Dm755 "$startdir"/files/write-bootcfg  "$pkgdir"/usr/libexec/mountnas/write-bootcfg
	install -Dm755 "$startdir"/files/gen-issue      "$pkgdir"/usr/libexec/mountnas/gen-issue
	install -Dm755 "$startdir"/files/pick-nic       "$pkgdir"/usr/libexec/mountnas/pick-nic
	install -Dm755 "$startdir"/files/data-watch     "$pkgdir"/usr/libexec/mountnas/data-watch
	install -Dm755 "$startdir"/files/notify         "$pkgdir"/usr/libexec/mountnas/notify
	install -Dm755 "$startdir"/files/smartd-notify  "$pkgdir"/usr/libexec/mountnas/smartd-notify
	install -Dm755 "$startdir"/files/health-digest  "$pkgdir"/usr/libexec/mountnas/health-digest
	# web dashboard: init script + renderer + refresher + static assets
	install -Dm755 "$startdir"/files/mountnas-web   "$pkgdir"/etc/init.d/mountnas-web
	install -Dm755 "$startdir"/files/gen-webstatus  "$pkgdir"/usr/libexec/mountnas/gen-webstatus
	install -Dm755 "$startdir"/files/web-refresh    "$pkgdir"/usr/libexec/mountnas/web-refresh
	install -Dm644 "$startdir"/files/web-guide.html "$pkgdir"/usr/share/mountnas/web/guide.html
	install -Dm644 "$startdir"/files/web-logo.png   "$pkgdir"/usr/share/mountnas/web/logo.png
	install -Dm755 "$startdir"/files/release-string "$pkgdir"/usr/libexec/mountnas/release-string
	install -Dm755 "$startdir"/files/periodic-datawatch "$pkgdir"/etc/periodic/15min/mountnas-datawatch
	install -Dm755 "$startdir"/files/issue-ifupdown "$pkgdir"/etc/network/if-up.d/mountnas-issue
	install -Dm644 "$startdir"/files/profile-nas-welcome.sh "$pkgdir"/etc/profile.d/nas-welcome.sh
	install -Dm644 "$startdir"/files/profile-nas-aliases.sh "$pkgdir"/etc/profile.d/nas-aliases.sh
	install -Dm644 "$startdir"/files/profile-nas-prompt.sh  "$pkgdir"/etc/profile.d/nas-prompt.sh
	install -Dm644 "$startdir"/files/profile-nas-resize.sh  "$pkgdir"/etc/profile.d/nas-resize.sh
	install -Dm644 "$startdir"/files/logo           "$pkgdir"/usr/share/mountnas/logo
	# shell completion: bash via profile.d (lbu-excluded), zsh via site-functions
	install -Dm644 "$startdir"/files/bash-nas-completion.sh "$pkgdir"/etc/profile.d/nas-completion.sh
	install -Dm644 "$startdir"/files/zsh-nas-completion     "$pkgdir"/usr/share/zsh/site-functions/_nas
	echo "$pkgver" | install -Dm644 /dev/stdin "$pkgdir"/usr/share/mountnas/version
	echo "$_reltag" | install -Dm644 /dev/stdin "$pkgdir"/usr/share/mountnas/release
}
