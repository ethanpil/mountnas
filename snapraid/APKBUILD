# Maintainer: MountNAS <ethan@piliavin.com>
# SnapRAID is only in Alpine edge/testing, so MountNAS compiles it from source
# against the stable base's own toolchain. The resulting apk lands in the same
# local repo as mountnas-tools and is installed by world like any other package.
pkgname=snapraid
pkgver=14.7
pkgrel=0
pkgdesc="Disk-array backup tool providing parity protection against data loss"
url="https://www.snapraid.it/"
arch="all"
license="GPL-3.0-or-later"
makedepends="linux-headers"
options="!check"
source="snapraid-$pkgver.tar.gz::https://github.com/amadvance/snapraid/releases/download/v$pkgver/snapraid-$pkgver.tar.gz"

build() {
	./configure \
		--prefix=/usr \
		--mandir=/usr/share/man
	make
}

package() {
	make DESTDIR="$pkgdir" install
	# Drop the man pages (snapraid ships 15 language translations). abuild requires
	# man pages gzipped or split into a -doc subpackage; an appliance image running
	# from RAM needs neither ('snapraid --help' covers usage), so just remove them.
	rm -rf "$pkgdir"/usr/share/man
}

# Committed (NOT regenerated in CI) so the pinned release is integrity-checked:
# if the GitHub asset is ever replaced, the build fails instead of shipping it.
# On a pkgver bump, refresh with: abuild checksum
sha512sums="
4e611e5d95a02702abbc8150375e74a1236094e0695792d155147a04dc71e1b1da327d4eb28702a424474adfc7e50cebc2d6b9daa55e78eeb70b384127a1b5bd  snapraid-14.7.tar.gz
"
