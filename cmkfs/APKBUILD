# Maintainer: MountNAS <ethan@piliavin.com>
# cmkfs (github.com/ethanpil/cmkfs) — a TUI for mkfs. Upstream publishes
# goreleaser-built apks, but they are unsigned/foreign-signed, which mkimage's
# isolated build root and the booted image do not trust — so the payload is
# repackaged under OUR build key (the zerotier-one pattern).
#
# ALWAYS-LATEST by maintainer decision: build.yml resolves the newest release
# tag from the GitHub API, seds it into pkgver, and regenerates the checksums
# (abuild checksum) before building — every MountNAS release ships the newest
# cmkfs. The pkgver/sha512sums committed here are a known-good fallback for
# local builds, not a pin.
pkgname=cmkfs
pkgver=0.3.1
pkgrel=0
pkgdesc="TUI for mkfs - guided filesystem creation"
url="https://github.com/ethanpil/cmkfs"
arch="x86_64"
license="custom"
options="!check"
source="cmkfs-$pkgver-amd64.apk::https://github.com/ethanpil/cmkfs/releases/download/v$pkgver/cmkfs_${pkgver}_linux_amd64.apk"
builddir="$srcdir"

build() { :; }

package() {
	# The upstream apk is itself a tarball; unpack its payload (usr/bin/cmkfs
	# + a man page) and install it, skipping the apk metadata (.PKGINFO/...).
	# Static Go binary — abuild finds no shared-library deps to trace.
	mkdir -p "$pkgdir"
	tar -xzf "$srcdir/cmkfs-$pkgver-amd64.apk" -C "$srcdir" 2>/dev/null || true
	cp -a "$srcdir/usr" "$pkgdir/usr"
	# appliance: no man pages on the box (same as snapraid/mergerfs)
	rm -rf "$pkgdir/usr/share/man"
}

sha512sums="
56714b54bf68041bc5e0e95ccbaf00b48c3545f4106f35c50e613f039bdd0e0348064f83b6e03396ad85cc09149f3859aeec9d13219014f9e6bd8df564c0dad0  cmkfs-0.3.1-amd64.apk
"
