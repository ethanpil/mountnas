# Maintainer: MountNAS <ethan@piliavin.com>
# mergerfs isn't in the stable repos, and the edge apk is unsafe to drop onto a
# stable userland (compiled against edge's libstdc++). Upstream, however, ships
# FULLY STATIC per-arch binaries with no libc/libstdc++ runtime dependency, so we
# simply repackage the official static release into a local apk. No compilation.
pkgname=mergerfs
pkgver=2.42.0
pkgrel=0
pkgdesc="Featureful union filesystem (upstream prebuilt static binary)"
url="https://github.com/trapexit/mergerfs"
arch="x86_64 aarch64 x86 riscv64"
license="ISC"
depends="fuse3"
options="!check !strip !tracedeps"

# Map the Alpine CARCH to upstream's release arch suffix.
case "$CARCH" in
	x86_64)  _ma="amd64"   ;;
	aarch64) _ma="arm64"   ;;
	x86)     _ma="i386"    ;;
	riscv64) _ma="riscv64" ;;
esac
source="mergerfs-$pkgver-static-linux_$_ma.tar.gz::https://github.com/trapexit/mergerfs/releases/download/$pkgver/mergerfs-$pkgver-static-linux_$_ma.tar.gz"
builddir="$srcdir"

build() { :; }

package() {
	# The static tarball mirrors a filesystem tree whose exact layout has shifted
	# across releases, so locate the binary instead of hardcoding. We skip the man
	# page on purpose: abuild requires it gzipped/-doc-split, and an appliance image
	# does not need it ('mergerfs --help' covers usage).
	local bin
	bin="$(find "$srcdir" -type f -name mergerfs | head -n1)"
	[ -n "$bin" ] || { error "mergerfs binary not found in static tarball"; return 1; }
	install -Dm755 "$bin" "$pkgdir"/usr/bin/mergerfs
	return 0
}

# Committed (NOT regenerated in CI) so the pinned release is integrity-checked:
# if the GitHub asset is ever replaced, the build fails instead of shipping it.
# The source filename is arch-dependent ($_ma); only the x86_64/amd64 tarball is
# built by CI today — when enabling another arch, append its tarball's sum here.
# On a pkgver bump, refresh with: abuild checksum
sha512sums="
c47f71183c19787f93653e2df6c65989eb7c7c4228132a7aa62dbd38b413d7fac90576ab52ae10a2c641c0d943ac398c3b06ad708cab2844ebc9f243dec90625  mergerfs-2.42.0-static-linux_amd64.tar.gz
"
